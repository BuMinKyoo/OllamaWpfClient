<Window x:Class="OllamaWpfClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:OllamaWpfClient.ViewModels"
        xmlns:models="clr-namespace:OllamaWpfClient.Models"
        xmlns:behaviors="clr-namespace:OllamaWpfClient.Behaviors"
        mc:Ignorable="d"
        Title="Ollama WPF Client" Height="640" Width="900"
        FontFamily="Segoe UI" FontSize="13">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="MessageBorder" TargetType="Border">
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="4"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Role}" Value="user">
                    <Setter Property="Background" Value="#E3F2FD"/>
                    <Setter Property="HorizontalAlignment" Value="Right"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Role}" Value="assistant">
                    <Setter Property="Background" Value="#F1F8E9"/>
                    <Setter Property="HorizontalAlignment" Value="Left"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Role}" Value="error">
                    <Setter Property="Background" Value="#FFEBEE"/>
                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top: model selector + actions -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="모델:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding AvailableModels}"
                      SelectedItem="{Binding SelectedModel}"
                      DisplayMemberPath="Name"
                      Height="28"/>
            <Button Grid.Column="2"
                    Content="새로고침"
                    Command="{Binding LoadModelsCommand}"
                    Margin="8,0,0,0" Padding="10,2" Height="28"/>
            <Button Grid.Column="3"
                    Content="대화 초기화"
                    Command="{Binding ClearConversationCommand}"
                    Margin="6,0,0,0" Padding="10,2" Height="28"/>
        </Grid>

        <!-- Messages list -->
        <Border Grid.Row="1" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4" Background="White">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="6">
                <ItemsControl ItemsSource="{Binding Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:ChatMessage}">
                            <Border Style="{StaticResource MessageBorder}" MaxWidth="700">
                                <StackPanel>
                                    <TextBlock Text="{Binding Role}"
                                               FontWeight="Bold"
                                               FontSize="11"
                                               Foreground="#555"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding Content}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Input -->
        <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="False"
                     TextWrapping="Wrap"
                     MinHeight="60" MaxHeight="160"
                     VerticalScrollBarVisibility="Auto"
                     FontFamily="Consolas"
                     behaviors:EnterKey.Command="{Binding SendCommand}"
                     behaviors:EnterKey.AllowShiftForNewline="True"/>
            <Button Grid.Column="1"
                    Content="보내기"
                    Command="{Binding SendCommand}"
                    Margin="8,0,0,0"
                    Padding="16,4"
                    MinWidth="80"/>
        </Grid>

        <!-- Action row -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <ProgressBar Width="120" Height="12"
                         IsIndeterminate="True"
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                         VerticalAlignment="Center"/>
            <Button Content="취소"
                    Command="{Binding CancelCommand}"
                    Margin="10,0,0,0" Width="80" Height="24"/>
        </StackPanel>

        <!-- Status -->
        <TextBlock Grid.Row="4"
                   Text="{Binding StatusMessage}"
                   Foreground="#666"
                   Margin="0,8,0,0"/>
    </Grid>
</Window>
